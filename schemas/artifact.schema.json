{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seif.efficientlabs.ai/schemas/artifact.schema.json",
  "title": "SEIF Artifact",
  "description": "Tangible structured output of a task. Accepted only through the evidence gate, never on a builder's narrative. The `allOf` gate enforces that an ACCEPTED verdict carries passed tests, an independent reviewer, and evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "task_id", "kind", "content_hash", "produced_by", "produced_at", "reality_state"],
  "properties": {
    "id": { "type": "string" },
    "task_id": { "type": "string" },
    "kind": { "enum": ["patch", "file", "report", "schema", "dataset", "plan", "review", "other"] },
    "path": { "type": ["string", "null"] },
    "content_hash": { "type": "string", "description": "sha256 of artifact content" },
    "produced_by": { "type": "string" },
    "produced_at": { "type": "string", "format": "date-time" },
    "reality_state": { "enum": ["LIVE", "WIRED", "STANDALONE", "MOCK", "FROZEN"] },
    "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [] },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tests_passed": { "type": ["boolean", "null"] },
        "reviewed_by": { "type": "array", "items": { "type": "string", "minLength": 1 }, "default": [], "description": "independent reviewers (non-empty); builder may NOT be sole authority" },
        "verdict": { "enum": ["ACCEPTED", "REJECTED", "PENDING"], "default": "PENDING" }
      }
    },
    "signature": { "type": ["string", "null"] }
  },
  "allOf": [
    {
      "$comment": "An ACCEPTED artifact must have passed tests, >=1 independent reviewer, and >=1 evidence ref.",
      "if": {
        "required": ["verification"],
        "properties": { "verification": { "required": ["verdict"], "properties": { "verdict": { "const": "ACCEPTED" } } } }
      },
      "then": {
        "required": ["evidence"],
        "properties": {
          "evidence": { "minItems": 1 },
          "verification": {
            "required": ["tests_passed", "reviewed_by"],
            "properties": { "tests_passed": { "const": true }, "reviewed_by": { "minItems": 1 } }
          }
        }
      }
    }
  ]
}
